{
  "expo": {
    "name": "VTL Executive",
    "slug": "vtl-executive",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/vtl-app-logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/vtl-app-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#080F1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vtl.executive",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/vtl-app-logo.png",
        "backgroundColor": "#080F1A"
      },
      "package": "com.vtl.executive",
      "compileSdkVersion": 35,
      "targetSdkVersion": 34,
      "buildToolsVersion": "35.0.0"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "vtl-executive",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f91246ea-3fca-4dbd-a6ce-89a8031dcabb"
      }
    }
  }
}
