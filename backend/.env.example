# Vilagio Inventory Management - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================
# DATABASE CONFIGURATION (Neon Tech PostgreSQL)
# ============================================================

# Get this from your Neon project dashboard
DATABASE_URL=postgresql://[username]:[password]@[host]/[database]?sslmode=require

# Alternative format if needed
DB_HOST=your-project.neon.tech
DB_PORT=5432
DB_NAME=vilagio_inventory
DB_USER=your_username
DB_PASSWORD=your_password
DB_SSL=true

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================

# Environment: development, staging, production
NODE_ENV=development

# Application port
PORT=3000

# Application URL (for webhooks, callbacks)
APP_URL=http://localhost:3000

# API versioning
API_VERSION=v1

# ============================================================
# AUTHENTICATION & SECURITY
# ============================================================

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT token expiration
JWT_EXPIRY=24h

# JWT refresh token expiration
JWT_REFRESH_EXPIRY=7d

# Bcrypt salt rounds for password hashing
BCRYPT_ROUNDS=10

# Session secret for express-session
SESSION_SECRET=your_session_secret_change_this

# CORS allowed origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# MCP SERVER CONFIGURATION
# ============================================================

# MCP server port
MCP_SERVER_PORT=3001

# Claude API key (get from Anthropic)
CLAUDE_API_KEY=your_anthropic_api_key_here

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4.5

# MCP tools enabled (comma separated)
MCP_TOOLS_ENABLED=inventory_query,stock_update,create_transaction,user_auth

# ============================================================
# EMAIL/NOTIFICATION CONFIGURATION
# ============================================================

EMAIL_SERVICE=smtp
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=re_JdRnJodi_4BuLrxnaNTLyK2cLhEjLU9P4
EMAIL_FROM="Vilagio ERP <wphiri@vilag.io>"

# ============================================================
# SMS NOTIFICATIONS (Optional)
# ============================================================

# Twilio configuration for SMS alerts
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SMS enabled
SMS_ENABLED=false

# ============================================================
# BARCODE SCANNER CONFIGURATION
# ============================================================

# Scanner webhook endpoint
SCANNER_WEBHOOK_URL=http://localhost:3000/api/v1/scanner/webhook

# Scanner session timeout (minutes)
SCANNER_SESSION_TIMEOUT=60

# Allowed scanner device IDs (comma separated, * for all)
ALLOWED_SCANNER_DEVICES=*

# ============================================================
# LOGGING & MONITORING
# ============================================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log format: json, simple
LOG_FORMAT=json

# Enable request logging
LOG_REQUESTS=true

# ============================================================
# FILE STORAGE (for future document attachments)
# ============================================================

# Storage type: local, s3
STORAGE_TYPE=local

# Local storage path
STORAGE_PATH=./uploads

# AWS S3 configuration (if using S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=vilagio-inventory-docs

# ============================================================
# RATE LIMITING
# ============================================================

# Max requests per window
RATE_LIMIT_MAX=100

# Time window in minutes
RATE_LIMIT_WINDOW=15

# ============================================================
# REPORTS & ANALYTICS
# ============================================================

# Enable analytics
ANALYTICS_ENABLED=true

# Report generation schedule (cron format)
# Daily at 6 AM: 0 6 * * *
DAILY_REPORT_SCHEDULE=0 6 * * *

# Report recipients (comma separated)
REPORT_RECIPIENTS=manager@vilagio.com,admin@vilagio.com

# ============================================================
# PRODUCTION SETTINGS (only for production environment)
# ============================================================

# Enable production optimizations
PRODUCTION_MODE=false

# Enable HTTPS
HTTPS_ENABLED=false

# SSL certificate paths
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# Sentry DSN for error tracking
SENTRY_DSN=your_sentry_dsn_here

# ============================================================
# FEATURE FLAGS
# ============================================================

# Enable batch tracking
FEATURE_BATCH_TRACKING=true

# Enable production orders
FEATURE_PRODUCTION_ORDERS=true

# Enable QC workflows
FEATURE_QC_WORKFLOWS=true

# Enable mobile scanner app
FEATURE_MOBILE_SCANNER=true

# Enable email notifications
FEATURE_EMAIL_NOTIFICATIONS=true

# Enable SMS notifications
FEATURE_SMS_NOTIFICATIONS=false

# ============================================================
# DEVELOPMENT SETTINGS
# ============================================================

# Enable debug mode
DEBUG=false

# Enable API documentation (Swagger)
API_DOCS_ENABLED=true

# Seed database with sample data on startup
SEED_DATABASE=false

# ============================================================
# NOTES
# ============================================================

# 1. Never commit .env file to version control
# 2. Use different values for development/staging/production
# 3. Rotate secrets regularly
# 4. Use environment-specific .env files (.env.development, .env.production)
# 5. For Neon database, always use SSL connection
